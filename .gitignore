# See https://help.github.com/articles/ignoring-files/ for about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (commit only .env.example)
.env
.env*.local
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# logs
*.log
dev.log
dev.out.log
server.log

# database (SQLite local data — do not commit user data)
db/*.db
db/*.db-journal

# sandbox / deployment scripts (project-specific, not part of source)
/.zscripts/
Caddyfile
upload/
examples/
mini-services/
download/

# editor / IDE
.idea/
.vscode/
*.swp

# OS
Thumbs.db

# Skills directory (internal tooling)
/skills/
.claude
.z-ai-config
prompt
test
local-*
