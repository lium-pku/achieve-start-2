// 小学生时间管理小程序 - 数据模型 v2.0（多用户）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 家庭（多租户隔离顶层）
model Family {
  id        String   @id @default(cuid())
  name      String   @default("我的家庭")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           Member[]
  users             User[]
  activities        Activity[]
  activityLogs      ActivityLog[]
  pointTransactions PointTransaction[]
  rewards           Reward[]
  redemptions      RewardRedemption[]
  encouragements    Encouragement[]
  goals             Goal[]
  reviews           Review[]
}

// 用户账号（登录身份，关联微信 openid）
model User {
  id        String   @id @default(cuid())
  familyId  String
  openid    String   @unique
  nickname  String?
  avatarUrl String?
  role      String   // 'mom' | 'dad' | 'child'
  memberId  String?  // 关联到 Member（角色卡）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family    Family   @relation(fields: [familyId], references: [id])
  member    Member?  @relation("UserMember", fields: [memberId], references: [id])

  @@index([familyId])
}

// 家庭成员（孩子 / 妈妈 / 爸爸）
model Member {
  id          String   @id @default(cuid())
  familyId    String
  name        String
  role        String   // "child" | "mom" | "dad"
  avatar      String   @default("🧒")
  color       String   @default("#FF9A3C")
  totalPoints Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family            Family   @relation(fields: [familyId], references: [id])
  users             User[]   @relation("UserMember")
  activityLogs      ActivityLog[]
  pointTransactions PointTransaction[]
  redemptions       RewardRedemption[]
  createdActivities Activity[]      @relation("CreatedActivities")
  assignedActivities Activity[]     @relation("AssignedActivities")
  createdRewards    Reward[]
  goals             Goal[]
  reviews           Review[]

  @@index([familyId])
}

// 活动 / 日程条目
model Activity {
  id            String   @id @default(cuid())
  familyId      String
  title         String
  description   String?
  scheduleType  String   // "daily" | "weekly" | "monthly" | "once"
  dayOfWeek     Int?     // 周度：1-7
  dayOfMonth    Int?     // 月度：1-31
  specificDate  DateTime? // 临时：具体日期（once 类型用）
  scheduledTime String?
  points        Int      @default(1)
  onTimeBonus   Int      @default(0)
  deadline      String?  // 截止时间 HH:mm（每天的截止时间）
  endDate       DateTime? // 截止日期（活动整体失效日期，如学期末）
  startDate     DateTime @default(now())
  active        Boolean  @default(true)
  createdById   String
  assignedToId  String?  // 兼容旧数据：主分配的孩子
  assignedToIds String?  // 多孩分配：逗号分隔的 memberId（空=公共活动=所有孩子）
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  family      Family   @relation(fields: [familyId], references: [id])
  createdBy   Member   @relation("CreatedActivities", fields: [createdById], references: [id])
  assignedTo  Member?  @relation("AssignedActivities", fields: [assignedToId], references: [id])
  logs        ActivityLog[]

  @@index([familyId])
}

// 活动完成记录
model ActivityLog {
  id             String   @id @default(cuid())
  familyId       String
  activityId     String
  memberId       String
  occurrenceDate DateTime
  status         String   // "pending_verification" | "completed" | "rejected" | "missed"
  onTime         Boolean  @default(false)
  pointsAwarded  Int      @default(0)
  bonusAwarded   Int      @default(0)
  completedAt    DateTime?
  operatorId     String?
  verifiedAt     DateTime?
  verifiedById   String?
  createdAt      DateTime @default(now())

  family    Family   @relation(fields: [familyId], references: [id])
  activity  Activity @relation(fields: [activityId], references: [id])
  member    Member   @relation(fields: [memberId], references: [id])

  @@unique([activityId, memberId, occurrenceDate])
  @@index([familyId])
  @@index([familyId, memberId, occurrenceDate])
}

// 积分流水
model PointTransaction {
  id          String   @id @default(cuid())
  familyId    String
  memberId    String
  amount      Int
  type        String   // "earn" | "bonus" | "penalty" | "redeem" | "adjust"
  reason      String
  activityId  String?
  createdAt   DateTime @default(now())

  family      Family   @relation(fields: [familyId], references: [id])
  member      Member   @relation(fields: [memberId], references: [id])

  @@index([familyId])
  @@index([memberId, createdAt])
}

// 奖励兑换项目
model Reward {
  id          String   @id @default(cuid())
  familyId    String
  title       String
  description String?
  icon        String   @default("🎁")
  pointsCost  Int
  active      Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family      Family            @relation(fields: [familyId], references: [id])
  createdBy   Member            @relation(fields: [createdById], references: [id])
  redemptions RewardRedemption[]

  @@index([familyId])
}

// 兑换记录
model RewardRedemption {
  id            String   @id @default(cuid())
  familyId      String
  rewardId      String
  memberId      String
  status        String   @default("pending") // "pending" | "approved" | "rejected" | "fulfilled"
  pointsSpent   Int
  note          String?
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?
  resolvedById  String?

  family        Family   @relation(fields: [familyId], references: [id])
  reward        Reward   @relation(fields: [rewardId], references: [id])
  member        Member   @relation(fields: [memberId], references: [id])

  @@index([familyId])
}

// 鼓励阈值
model Encouragement {
  id          String   @id @default(cuid())
  familyId    String
  threshold   Int
  title       String
  message     String
  icon        String   @default("🌟")
  createdAt   DateTime @default(now())

  family      Family   @relation(fields: [familyId], references: [id])

  @@index([familyId])
}

// 个人长期目标
model Goal {
  id          String   @id @default(cuid())
  familyId    String
  title       String
  description String?
  status      String   @default("not_started") // "not_started" | "in_progress" | "achieved"
  deadline    DateTime?
  memberId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family      Family   @relation(fields: [familyId], references: [id])
  member      Member   @relation(fields: [memberId], references: [id])

  @@index([familyId])
}

// 复盘点评
model Review {
  id          String   @id @default(cuid())
  familyId    String
  periodType  String   // "weekly" | "monthly"
  periodStart DateTime
  periodEnd   DateTime
  authorId    String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family      Family   @relation(fields: [familyId], references: [id])
  author      Member   @relation(fields: [authorId], references: [id])

  @@index([familyId])
}
